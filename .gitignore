# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / IDE (personal dev settings, not runtime)
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# agent / AI tooling (not runtime)
.claude/
.agents/
.cursor/
CLAUDE.md
AGENTS.md
.cursorrules
skills-lock.json
tasks/

# design mockup reference (JSX playground, not used at runtime)
base/

# project docs (not required to run the app)
context.md
database_schema.json

# logs
*.log
logs/
